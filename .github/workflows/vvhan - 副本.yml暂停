name: vvhan

on:
  workflow_dispatch:

permissions:
  contents: write

jobs:
  fetch-and-save:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install Dependencies
        run: pip install requests

      - name: Process API Data
        run: |
          python << 'EOF'
          import requests
          import os
          from datetime import datetime, timedelta

          # 1. 获取北京时间 (仅用于写入文件时的显示)
          bj_time = (datetime.utcnow() + timedelta(hours=8)).strftime('%m-%d %H:%M')
          
          url = "https://api.4ce.cn/api/bestCFIP"
          ip_nodes = []
          
          # 2. 抓取并解析数据
          try:
              print(f"正在请求数据源: {url}")
              response = requests.get(url, timeout=15)
              res_json = response.json()
              
              if res_json.get("success"):
                  v4_data = res_json.get("data", {}).get("v4", {})
                  # 按照 移动 -> 联通 -> 电信 排序
                  order = [("CM", "移动"), ("CU", "联通"), ("CT", "电信")]

                  for key, label in order:
                      nodes = v4_data.get(key, [])
                      for node in nodes:
                          ip = node.get("ip")
                          colo = node.get("colo", "Unknown")
                          if ip:
                              # 格式化节点信息
                              line = f"{ip}:443#{label}|{colo}|{ip}"
                              ip_nodes.append(line)
              else:
                  print("API 返回状态为失败")
          except Exception as e:
              print(f"抓取过程中出现异常: {e}")

          # 3. 核心对比逻辑：判断内容是否有实质性变化
          dir_name = "vvhan"
          os.makedirs(dir_name, exist_ok=True)
          file_path = os.path.join(dir_name, "all.txt")
          
          should_write = True
          if os.path.exists(file_path):
              with open(file_path, "r", encoding="utf-8") as f:
                  old_content = f.readlines()
                  # 关键：切片 [1:-1] 剔除旧文件的第一行（旧时间）和最后一行，只比对中间的 IP
                  old_ips = [line.strip() for line in old_content[1:-1] if line.strip()]
                  
                  if old_ips == ip_nodes:
                      print("检测到 IP 节点内容完全一致，跳过文件写入以防止虚假提交。")
                      should_write = False

          # 4. 只有内容变化时才写入文件
          if should_write and ip_nodes:
              final_output = []
              final_output.append(f"saas.sin.fan:443#▼ 优选IP | {bj_time} | YouTube@真香定律")
              final_output.extend(ip_nodes)
              final_output.append("bestcf.030101.xyz:443#▲ 优选IP | 分享优选网 bestcf.pages.dev | 感谢vvHan")
              
              with open(file_path, "w", encoding="utf-8") as f:
                  f.write("\n".join(final_output))
              print(f"处理完成！成功更新 {len(ip_nodes)} 个节点。")
          elif not ip_nodes:
              print("未抓取到任何有效节点，放弃本次操作。")
          EOF

      - name: Commit and Push
        run: |
          git config --local user.email "github-actions[bot]@users.noreply.github.com"
          git config --local user.name "github-actions[bot]"
          
          # 只有文件内容确实被 Python 修改了，这里才会有 staged changes
          git add vvhan/all.txt
          
          if git diff --staged --quiet; then
            echo "没有检测到文件改动，跳过提交。"
          else
            BJ_TIME=$(TZ='Asia/Shanghai' date +'%Y-%m-%d %H:%M:%S')
            git commit -m "Auto Update vvHan IPs: $BJ_TIME"
            
            # 解决推送冲突的核心：拉取远程并变基
            git pull --rebase origin main
            git push origin main
          fi
